// Unit tests for ReverseProxy — the network-free surface: longest-
// prefix routing, hop-by-hop classification, X-Forwarded-For chain
// building. The actual upstream round-trip (Handle → HttpClient.Send)
// needs a live backend and is exercised manually / in integration —
// see the README's "End-to-end" snippet.

namespace Tests

import Amalgame.Collections
import Amalgame.String
import Amalgame.Net.Http
import Amalgame.Net.Proxy

public class Program {
    public static void Main(string[] args) {
        Console.WriteLine("amalgame-net-proxy — ReverseProxy tests")

        // ── 1. Longest-prefix routing, order-independent ─────────
        let p = ReverseProxy.New()
            .Forward("/",        "http://web:8080")
            .Forward("/api",     "http://api:8081")
            .Forward("/api/v2",  "http://api-v2:8082")
        if (p.MatchBackend("/api/v2/users") == "http://api-v2:8082") {
            Console.WriteLine("[PASS] longest prefix wins (/api/v2 over /api over /)")
        } else {
            Console.WriteLine("[FAIL] longest prefix: " + p.MatchBackend("/api/v2/users"))
        }

        // ── 2. Shorter prefix still routes correctly ─────────────
        if (p.MatchBackend("/api/users") == "http://api:8081") {
            Console.WriteLine("[PASS] /api/users → /api backend")
        } else {
            Console.WriteLine("[FAIL] /api/users → " + p.MatchBackend("/api/users"))
        }

        // ── 3. Catch-all "/" handles the rest ────────────────────
        if (p.MatchBackend("/about") == "http://web:8080") {
            Console.WriteLine("[PASS] catch-all / routes unmatched paths")
        } else {
            Console.WriteLine("[FAIL] catch-all: " + p.MatchBackend("/about"))
        }

        // ── 4. Prefix boundary: /api must NOT match /apixyz ──────
        let p2 = ReverseProxy.New().Forward("/api", "http://api:8081")
        if (p2.MatchBackend("/apixyz") == "" && p2.MatchBackend("/api") == "http://api:8081") {
            Console.WriteLine("[PASS] prefix boundary (/api ≠ /apixyz, /api == /api)")
        } else {
            Console.WriteLine("[FAIL] boundary: apixyz=" + p2.MatchBackend("/apixyz") + " api=" + p2.MatchBackend("/api"))
        }

        // ── 5. No route → empty (Handle turns this into 502) ─────
        let p3 = ReverseProxy.New().Forward("/api", "http://api:8081")
        if (p3.MatchBackend("/static/x.png") == "") {
            Console.WriteLine("[PASS] no matching route → \"\"")
        } else {
            Console.WriteLine("[FAIL] no-route should be empty")
        }

        // ── 6. Hop-by-hop classification ─────────────────────────
        let hopOk: bool = ReverseProxy.IsHopByHop("connection")
            && ReverseProxy.IsHopByHop("transfer-encoding")
            && ReverseProxy.IsHopByHop("host")
            && ReverseProxy.IsHopByHop("content-length")
        let passThru: bool = !ReverseProxy.IsHopByHop("content-type")
            && !ReverseProxy.IsHopByHop("authorization")
            && !ReverseProxy.IsHopByHop("set-cookie")
        if (hopOk && passThru) {
            Console.WriteLine("[PASS] hop-by-hop dropped, app headers passed through")
        } else {
            Console.WriteLine("[FAIL] hop-by-hop classification")
        }

        // ── 7. X-Forwarded-For: fresh request → just the client IP ─
        let req = new HttpRequest()
        req.RemoteAddr = "192.0.2.7:55001"
        if (p.ForwardedFor(req) == "192.0.2.7") {
            Console.WriteLine("[PASS] XFF strips :port → client IP")
        } else {
            Console.WriteLine("[FAIL] XFF fresh: " + p.ForwardedFor(req))
        }

        // ── 8. X-Forwarded-For: append to an existing chain ──────
        let req2 = new HttpRequest()
        req2.RemoteAddr = "192.0.2.7:55001"
        req2.Headers.Set("x-forwarded-for", "203.0.113.5")
        if (p.ForwardedFor(req2) == "203.0.113.5, 192.0.2.7") {
            Console.WriteLine("[PASS] XFF appends to an inbound chain")
        } else {
            Console.WriteLine("[FAIL] XFF append: " + p.ForwardedFor(req2))
        }

        // ── 9. Round-robin cycles through all backends ───────────
        let rr = UpstreamPool.New()
            .Add("http://n1:8080")
            .Add("http://n2:8080")
            .Add("http://n3:8080")
            .RoundRobin()
        let a1: string = rr.Pick("")
        let a2: string = rr.Pick("")
        let a3: string = rr.Pick("")
        let a4: string = rr.Pick("")
        // 3 distinct over 3 picks, then wraps to the first.
        let rrCycles: bool = a1 != a2 && a2 != a3 && a1 != a3 && a4 == a1
        if (rrCycles) {
            Console.WriteLine("[PASS] round-robin cycles n1→n2→n3→n1")
        } else {
            Console.WriteLine("[FAIL] round-robin: " + a1 + "," + a2 + "," + a3 + "," + a4)
        }

        // ── 10. Weighted round-robin honours weights ─────────────
        let wrr = UpstreamPool.New()
            .AddWeighted("http://big:8080", 2)
            .AddWeighted("http://small:8080", 1)
            .RoundRobin()
        var bigCount: int = 0
        for i in 0..3 {
            if (wrr.Pick("") == "http://big:8080") { bigCount = bigCount + 1 }
        }
        // weight 2 vs 1 over a 3-pick cycle → big twice, small once.
        if (bigCount == 2) {
            Console.WriteLine("[PASS] weighted RR: weight-2 backend gets 2/3 of the turns")
        } else {
            Console.WriteLine("[FAIL] weighted RR big count: " + String_FromInt(bigCount))
        }

        // ── 11. ip_hash is sticky (same IP → same backend) ───────
        let ih = UpstreamPool.New()
            .Add("http://x:8080")
            .Add("http://y:8080")
            .Add("http://z:8080")
            .IpHash()
        let pa: string = ih.Pick("203.0.113.9")
        let pb: string = ih.Pick("203.0.113.9")
        let inPool: bool = pa == "http://x:8080" || pa == "http://y:8080" || pa == "http://z:8080"
        if (pa == pb && inPool) {
            Console.WriteLine("[PASS] ip_hash sticky: same IP → same backend")
        } else {
            Console.WriteLine("[FAIL] ip_hash: " + pa + " vs " + pb)
        }

        // ── 12. ForwardPool wires a pool into a route ────────────
        let app12 = ReverseProxy.New()
            .Forward("/", "http://web:8080")
            .ForwardPool("/api", UpstreamPool.New().Add("http://api1:9").Add("http://api2:9").RoundRobin())
        let routeApi: ProxyRoute = app12.MatchRoute("/api/users")
        let routeWeb: ProxyRoute = app12.MatchRoute("/about")
        let poolOk: bool = routeApi != null && routeApi.Pool != null
            && routeWeb != null && routeWeb.Pool == null && routeWeb.Backend == "http://web:8080"
        if (poolOk) {
            Console.WriteLine("[PASS] ForwardPool: /api → pool, / → single backend")
        } else {
            Console.WriteLine("[FAIL] ForwardPool routing")
        }

        // ── 13. Least-connections spreads load + Release frees slot ─
        let lc = UpstreamPool.New()
            .Add("http://a:1")
            .Add("http://b:1")
            .Add("http://c:1")
            .LeastConnections()
        let q1: UpstreamBackend = lc.PickBackend("")   // a (all 0, tie→first)
        let q2: UpstreamBackend = lc.PickBackend("")   // b (a now 1)
        let q3: UpstreamBackend = lc.PickBackend("")   // c
        let spread: bool = q1.Url != q2.Url && q2.Url != q3.Url && q1.Url != q3.Url
        // release q1 → its backend drops to 0 in-flight; next pick takes it.
        lc.Release(q1)
        let q4: UpstreamBackend = lc.PickBackend("")
        if (spread && q4.Url == q1.Url) {
            Console.WriteLine("[PASS] least-connections spreads load + Release frees the slot")
        } else {
            Console.WriteLine("[FAIL] least-conn: spread=" + q1.Url + "," + q2.Url + "," + q3.Url + " q4=" + q4.Url)
        }

        Console.WriteLine("done")
    }
}
